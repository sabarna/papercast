# ---- Required API key (OpenAI powers narration + text-to-speech) ----
OPENAI_API_KEY=sk-your-key-here

# ---- Model selection (optional) ----
NARRATIVE_MODEL=gpt-5.5
TTS_MODEL=tts-1
TTS_VOICE=alloy

# ---- Video tuning (optional) ----
TARGET_DURATION_S=420        # target video length in seconds; 420 = 7 min
SLIDE_WIDTH=1920
SLIDE_HEIGHT=1080
SLIDE_FPS=30

# ---- Paths (optional) ----
WORKSPACE_DIR=./workspace

# ---- Optional Basic Auth for the web UI ----
# Leave blank to run the UI with no login (fine for localhost).
# Set BOTH if you expose the UI on a network so nobody else can spend your API credits.
APP_USERNAME=
APP_PASSWORD=
